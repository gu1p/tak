# Local-client image for the real-Tor takd relay test.
#
# This image contains `tak` plus a local `takd` bridge. The bridge is still a
# real daemon with real Tor/HTTP/2 connections to the remote node.
FROM debian:trixie-slim

RUN apt-get update \
    && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        bash \
        ca-certificates \
        coreutils \
        findutils \
        grep \
        sed \
        tar \
    && rm -rf /var/lib/apt/lists/*

COPY takd /usr/local/bin/takd
COPY tak /usr/local/bin/tak

ENV MOCK_CONTAINER=true
ENV RUST_LOG=warn,takd=info,takd::daemon::peer_manager=debug,takd::daemon::protocol::broker=debug,tak_exec=info
ENV HOME=/root

WORKDIR /work
CMD ["tak", "--help"]
